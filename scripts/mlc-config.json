{
  "ignorePatterns": [
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^http://localhost"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^\\./",
      "replacement": ""
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 2,
  "fallbackRetryDelay": "3s",
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308, 403, 429]
}
